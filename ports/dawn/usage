To use Dawn/tint in your project:

    find_package(Dawn CONFIG REQUIRED)
    target_link_libraries(main
        PRIVATE
            # Dawn targets, if you haven't disabled it with `skip-building-dawn` feature
            dawn::dawncpp_headers
            dawn::dawn_native
            dawn::dawn_proc
            #
            # tint targets
            dawn::tint_api
            #
            # there are more Dawn/tint targets available, but you'll have to find out
            # yourself whichever of those you actually need in your project
    )
